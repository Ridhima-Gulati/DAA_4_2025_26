#include <bits/stdc++.h>
using namespace std;
class Solution {
public:
    int minDifference(vector<int>& arr) {
        int n = arr.size();
        int total = 0;
        for (int x : arr) total += x;
        int target = total / 2;
        vector<bool> dp(target + 1, false);
        dp[0] = true;
        for (int num : arr) {
            for (int j = target; j >= num; j--) {
                dp[j] = dp[j] || dp[j - num];
            }
        }
        for (int s1 = target; s1 >= 0; s1--) {
            if (dp[s1]) {
                return total - 2 * s1;
            }
        }
        return 0;
    }
};
int main() {
    int n;
    cin >> n;
    vector<int> arr(n);
    for (int i = 0; i < n; i++) cin >> arr[i];
    Solution obj;
    cout << obj.minDifference(arr);
    return 0;
}
